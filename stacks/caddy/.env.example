# Cloudflare API token — scoped to DNS Edit for longie.net zone only
# Create at: Cloudflare dashboard → My Profile → API Tokens → Create Token → Edit zone DNS
# Set this in Portainer's Environment Variables UI (never commit the real value)
CLOUDFLARE_API_TOKEN=

# Cloudflare Tunnel token — from Zero Trust → Networking → Tunnels → longie-caddy → Configure → Token
# Set this in Portainer's Environment Variables UI (never commit the real value)
# WARNING: visible via `docker inspect` and Portainer UI — MFA on Cloudflare account is primary control
# If compromised: revoke via Cloudflare dashboard and verify only one connector is active
CLOUDFLARE_TUNNEL_TOKEN=

# DOCKER_DATA_HOME must be set in Portainer's Environment Variables UI.

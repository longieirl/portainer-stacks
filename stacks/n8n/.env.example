# Postgres password — used by both the postgres and n8n services
# Set this in Portainer's Environment Variables UI (never commit the real value)
POSTGRES_PASSWORD=

# Encryption key for stored credentials (API keys, OAuth tokens, etc.)
# Generate once: openssl rand -hex 32
# CRITICAL: back this up — losing it makes all stored credentials unreadable
N8N_ENCRYPTION_KEY=

# Cloudflare Tunnel token — from Zero Trust → Networking → Tunnels → your tunnel
# Set this in Portainer's Environment Variables UI (never commit the real value)
CLOUDFLARE_TUNNEL_TOKEN=
